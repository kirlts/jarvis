# Jarvis – Environment Variables
# Copy to .env and adjust values for your environment.
# Stack versions: April 2026 (see docker-compose.yml header)

# Server
HOST=0.0.0.0
PORT=3000

# PostgreSQL (direct – migrations, admin, pg-boss)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres_sandbox
DB_NAME=jarvis

# Pooler (HTTP application traffic – PgBouncer in transaction mode)
# Maps externally to 6543, internally PgBouncer listens on 5432
POOLER_HOST=localhost
POOLER_PORT=6543

# S3 Storage (MinIO, source build in sandbox)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin_sandbox
STORAGE_BUCKET=jarvis-files

# pg-boss (MUST use direct PG, NOT pooler – advisory locks need session continuity)
BOSS_DATABASE_URL=postgresql://postgres:postgres_sandbox@localhost:5432/jarvis

# JWT (Phase 1: symmetric HS256. Phase 2: rotate secret via CI/CD)
JWT_SECRET=jarvis-sandbox-secret-change-in-production
