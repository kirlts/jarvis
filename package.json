{
  "name": "jarvis",
  "version": "0.1.0",
  "description": "B2B SaaS Core – Operations & Personnel Management",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "worker:dev": "node --watch src/workers/boss-worker.js",
    "worker:start": "node src/workers/boss-worker.js",
    "sandbox:up": "docker compose up -d --build",
    "sandbox:down": "docker compose down -v",
    "sandbox:health": "node scripts/health-check.js",
    "test": "node --test src/**/*.test.js",
    "test:unit": "node --test src/features/**/*.test.js src/rls.test.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-presigned-post": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/sensible": "^6.0.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pg-boss": "^12.10.0",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.1",
    "@testcontainers/postgresql": "^11.14.0",
    "fast-check": "^4.7.0",
    "k6": "^0.0.0",
    "specmatic": "^2.44.1",
    "testcontainers": "^11.14.0"
  },
  "private": true,
  "license": "UNLICENSED"
}
