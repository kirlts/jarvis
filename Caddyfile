{
	local_certs
}

http://api.jarvis.local, https://api.jarvis.local {
	reverse_proxy core-api:3000

	header {
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
}

http://admin.jarvis.local, https://admin.jarvis.local {
	reverse_proxy appsmith:80

	header {
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	}
}

:80, :443 {
	respond "Not Found" 404
}
